# Get your Privy App ID at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Get your API token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# Video generation model (image-to-video)
# Options: minimax/video-01-live, wavespeedai/wan-2.1-i2v-480p
REPLICATE_MODEL=minimax/video-01-live

# Starting credits for new users
INITIAL_CREDITS=100

# Treasury wallet that receives $ZORIA token payments (BSC)
ZORIA_TREASURY_WALLET=0x_your_treasury_wallet_here
NEXT_PUBLIC_ZORIA_TREASURY=0x_your_treasury_wallet_here
